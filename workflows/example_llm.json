{
  "name": "example_llm_workflow",
  "description": "适合 LLM 读取的 JSON 工作流示例",
  "tasks": [
    {
      "id": "analyze",
      "instruction": "分析代码库结构，识别关键组件",
      "inputs": [],
      "outputs": ["refactor", "document"]
    },
    {
      "id": "refactor",
      "instruction": "根据分析结果重构已识别的组件",
      "inputs": ["analyze"],
      "outputs": ["test"]
    },
    {
      "id": "document",
      "instruction": "为已分析组件生成文档",
      "inputs": ["analyze"],
      "outputs": ["review"]
    },
    {
      "id": "test",
      "instruction": "运行测试，验证重构后的代码行为正确",
      "inputs": ["refactor"],
      "outputs": ["review"],
      "loop": {
        "max_iterations": 3,
        "until_condition": "all_tests_pass == true",
        "retry_on_failure": true
      }
    },
    {
      "id": "review",
      "instruction": "审查全部改动并生成汇总报告",
      "inputs": ["document", "test"],
      "outputs": []
    }
  ]
}
